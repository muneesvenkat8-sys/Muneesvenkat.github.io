<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>munees | Mechanical Engineer</title>

<style>

/* RESET */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}

/* BODY */
body {
    background: #0f172a;
    color: white;
    scroll-behavior: smooth;
}

/* NAVBAR */
nav {
    display: flex;
    justify-content: space-between;
    padding: 20px 50px;
    background: #020617;
    position: sticky;
    top: 0;
}

nav h1 {
    color: #38bdf8;
}

nav ul {
    display: flex;
    list-style: none;
}

nav ul li {
    margin-left: 20px;
}

nav ul li a {
    color: white;
    text-decoration: none;
    transition: 0.3s;
}

nav ul li a:hover {
    color: #38bdf8;
}

/* HERO */
.hero {
    text-align: center;
    padding: 120px 20px;
}

.hero h2 {
    font-size: 42px;
    color: #38bdf8;
}

.hero p {
    margin-top: 10px;
    font-size: 18px;
}

/* SECTION */
.section {
    padding: 50px;
    margin: 20px;
    background: #1e293b;
    border-radius: 15px;
    transition: 0.3s;
}

.section:hover {
    transform: translateY(-5px);
}

/* SKILLS CARDS */
.skills-container {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
}

.skill-card {
    background: #020617;
    padding: 20px;
    border-radius: 10px;
    flex: 1;
    text-align: center;
    transition: 0.3s;
}

.skill-card:hover {
    background: #38bdf8;
    color: black;
}

/* CONTACT BUTTON */
.contact-btn {
    display: inline-block;
    margin-top: 10px;
    padding: 10px 15px;
    background: #38bdf8;
    color: black;
    border-radius: 5px;
    text-decoration: none;
}

/* FOOTER */
footer {
    text-align: center;
    padding: 20px;
    color: gray;
}

</style>
</head>

<body>

<!-- NAVBAR -->
<nav>
    <h1>munees</h1>
    <ul>
        <li><a href="#">Home</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#projects">Projects</a></li>
        <li><a href="#contact">Contact</a></li>
    </ul>
</nav>

<!-- HERO -->
<div class="hero">
    <h2>Mechanical Engineering Student</h2>
    <p>Future Design Engineer | Passionate about CAD</p>
</div>

<!-- ABOUT -->
<div class="section" id="about">
    <h2>About Me</h2>
    <p>
        I am munees, a 2nd year Mechanical Engineering student.
        I am passionate about CAD design and mechanical systems.
    </p>
</div>

<!-- SKILLS -->
<div class="section" id="skills">
    <h2>Skills</h2>
    <div class="skills-container">
        <div class="skill-card">CAD Design</div>
        <div class="skill-card">C Programming</div>
        <div class="skill-card">Machine Operation</div>
    </div>
</div>

<!-- PROJECTS -->
<div class="section" id="projects">
    <h2>Projects</h2>
    <p>Projects will be updated soon...</p>
</div>

<!-- GOALS -->
<div class="section">
    <h2>Goals</h2>
    <p>
        To become a professional mechanical design engineer and work in top companies.
    </p>
</div>

<!-- CONTACT -->
<div class="section" id="contact">
    <h2>Contact</h2>
    <p>📞 +91 9360441259</p>
    <p>📧 muneesvenkat8@gmail.com</p>
    <a href="mailto: muneesvenkat8@gmail.com" class="contact-btn">Send Email</a>
</div>

<!-- FOOTER -->
<footer>
    <p>© 2026 munees</p>
</footer>

</body>
</html>
